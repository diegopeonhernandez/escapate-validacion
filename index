<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Escapate · Validación de Mercado</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;1,9..144,300;1,9..144,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* --- PANTALLA DE ACCESO --- */
#login-screen {
    position: fixed; inset: 0; background: #2c4f12; z-index: 9999;
    display: flex; align-items: center; justify-content: center; font-family: 'DM Sans', sans-serif;
}
.login-box { background: #f2ece0; padding: 40px; border-radius: 14px; text-align: center; max-width: 400px; width: 90%; box-shadow: 0 20px 50px rgba(0,0,0,0.3); }
.login-box h2 { font-family: 'Fraunces', serif; color: #2c4f12; margin-bottom: 10px; }
.login-box p { font-size: 14px; color: #8a8070; margin-bottom: 24px; }
.login-box input { width: 100%; padding: 14px; margin-bottom: 16px; border: 1.5px solid rgba(26,23,16,0.1); border-radius: 8px; font-size: 18px; text-align: center; outline: none; }
.login-box button { background: #2c4f12; color: white; border: none; padding: 14px 40px; border-radius: 100px; font-weight: 600; cursor: pointer; width: 100%; }
#login-error { color: #9e2a2a; font-size: 13px; margin-top: 12px; display: none; }

/* --- ESTILOS DE LA ENCUESTA --- */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#f2ece0;--ink:#1a1710;--cream:#faf6ee;
  --verde:#2c4f12;--verde2:#3d6b1a;--verde-l:#e8f2de;
  --ocre:#c0882a;--ocre-l:#fdf0d8;--muted:#8a8070;--border:rgba(26,23,16,0.10);
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh}
.hero{background:var(--verde);padding:48px 40px 60px;position:relative;overflow:hidden;color:white}
.hero-eye{font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--ocre);margin-bottom:14px}
.hero h1{font-family:'Fraunces',serif;font-size:clamp(32px,6vw,56px);font-weight:300;line-height:1.05;margin-bottom:12px}
.hero h1 em{font-style:italic;color:var(--ocre)}
.prog-bar-wrap{padding:20px 40px;background:var(--cream);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50}
.prog-track{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-bottom:6px}
.prog-fill{height:100%;background:var(--verde);transition:width 0.4s ease}
.survey-body{max-width:680px;margin:0 auto;padding:40px 40px 80px}
.q-block{display:none}
.q-block.active{display:block;animation:fadeUp 0.4s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.q-num{font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--ocre);margin-bottom:8px}
.q-text{font-family:'Fraunces',serif;font-size:24px;font-weight:300;line-height:1.3;margin-bottom:24px}
.opts{display:flex;flex-direction:column;gap:9px}
.opt{padding:13px 16px;border:1.5px solid var(--border);border-radius:10px;cursor:pointer;background:var(--cream);display:flex;align-items:center;gap:10px;text-align:left;width:100%;font-family:inherit}
.opt.sel{border-color:var(--verde);background:var(--verde-l);font-weight:500}
.chk{width:20px;height:20px;border-radius:50%;border:1.5px solid var(--border);margin-left:auto;display:flex;align-items:center;justify-content:center;font-size:10px}
.q-nav{display:flex;justify-content:space-between;margin-top:28px;padding-top:20px;border-top:1px solid var(--border)}
.btn-p,.btn-n{padding:11px 24px;border-radius:100px;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;font-weight:500}
.btn-p{background:var(--cream);border:1.5px solid var(--border);color:var(--muted)}
.btn-n{background:var(--verde);color:white}
.thanks{display:none;text-align:center;padding:60px 40px}
.thanks.show{display:block}
.q-ta{width:100%;min-height:90px;padding:15px;border-radius:10px;border:1.5px solid var(--border);font-family:inherit;outline:none}
.sc-btn{flex:1;height:42px;border:1.5px solid var(--border);border-radius:8px;cursor:pointer;font-family:inherit}
.sc-btn.sel{background:var(--verde);color:white;border-color:var(--verde)}
</style>
</head>
