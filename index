<script>
// --- CONTROL DE ACCESO ---
function login() {
  const code = document.getElementById('pass').value;
  if(code.toUpperCase() === "ESCAPATE") { // TU CÓDIGO DE ACCESO
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('survey-content').style.display = 'block';
  } else { 
    document.getElementById('login-error').style.display = 'block'; 
  }
}

// --- LÓGICA DE NAVEGACIÓN ---
let currentStep = 1;
const answers = {};

function pick(el, qid) {
  el.closest('.opts').querySelectorAll('.opt').forEach(o => {
    o.classList.remove('sel'); 
    o.querySelector('.chk').textContent = '';
  });
  el.classList.add('sel'); 
  el.querySelector('.chk').textContent = '✓';
  answers[qid] = el.innerText.replace('✓','').trim();
}

function multi(el, qid) {
  el.classList.toggle('sel'); 
  el.querySelector('.chk').textContent = el.classList.contains('sel') ? '✓' : '';
  const selected = []; 
  el.closest('.opts').querySelectorAll('.opt.sel').forEach(o => {
    selected.push(o.innerText.replace('✓','').trim());
  });
  answers[qid] = selected.join(', ');
}

function scale(el, groupId, qid) {
  document.querySelectorAll(`#${groupId} .sc-btn`).forEach(b => b.classList.remove('sel'));
  el.classList.add('sel'); 
  answers[qid] = el.innerText;
}

function go(n) {
  document.querySelectorAll('.q-block').forEach(b => b.classList.remove('active'));
  document.getElementById('q'+n).classList.add('active');
  currentStep = n;
  document.getElementById('pf').style.width = (n-1)/18*100 + '%';
  document.getElementById('qnum').innerText = "Pregunta "+n+" de 18";
  window.scrollTo(0,0);
}

// --- ENVÍO A FORMSPREE ---
async function submit() {
  answers['q18'] = document.getElementById('ta18').value;
  document.getElementById('q18').style.display = 'none';
  document.getElementById('saving').style.display = 'block';

  const FORMSPREE_ID = "meepnyjo"; // TU CÓDIGO REAL
  const URL = "https://formspree.io/f/" + FORMSPREE_ID;

  try {
    const response = await fetch(URL, {
      method: 'POST', 
      body: JSON.stringify(answers),
      headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' }
    });
    
    if(response.ok) {
